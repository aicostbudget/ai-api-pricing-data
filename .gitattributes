# Normalize text files across Windows and WSL.
* text=auto

# Source code and structured data use LF.
*.py text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.csv text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.cff text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf

# Native Windows batch scripts use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
